{
  "name": "stw-live-data",
  "private": true,
  "version": "0.1.0",
  "description": "STW Companion daily data collector and static home.json generator.",
  "type": "module",
  "scripts": {
    "extract:power": "node scripts/extract-power-levels.mjs",
    "collect": "tsx src/collect.ts",
    "update": "tsx src/update-home.ts",
    "make:fixture": "tsx src/make-fixture.ts",
    "build:home": "tsx src/build-home.ts",
    "build:home:fixture": "tsx src/build-home.ts --fixture",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
